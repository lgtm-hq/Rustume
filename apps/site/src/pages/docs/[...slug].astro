---
import { getCollection, getEntry, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import DocsStandaloneLayout from '../../layouts/DocsStandaloneLayout.astro';
import PricingTable from '../../components/PricingTable.astro';
import { isStandaloneCategory } from '../../data/docs-nav';
import { collectDocResources } from '../../lib/doc-resources';
import type { DocCategory } from '../../data/docs-nav';

export async function getStaticPaths() {
  const docs = await getCollection('docs', ({ data }) => !data.draft);
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const category = doc.data.category as DocCategory;
const standalone = isStandaloneCategory(category);
const isPricingPlans = doc.id === 'pricing/plans';
const resourceMarkdown: string[] = doc.body ? [doc.body] : [];

let TailContent: Awaited<ReturnType<typeof render>>['Content'] | null = null;
if (isPricingPlans) {
  const tail = await getEntry('docs', 'pricing/plans-body');
  if (tail) {
    if (tail.body) resourceMarkdown.push(tail.body);
    ({ Content: TailContent } = await render(tail));
  }
}

const resources = collectDocResources({
  description: doc.data.description,
  markdown: resourceMarkdown,
});
---

{
  standalone ? (
    <DocsStandaloneLayout
      title={doc.data.title}
      description={doc.data.description}
      slug={doc.id}
      category={category}
      resources={resources}
      toc={doc.data.toc}
    >
      {isPricingPlans ? (
        <>
          <Content />
          <PricingTable />
          {TailContent && <TailContent />}
        </>
      ) : (
        <Content />
      )}
    </DocsStandaloneLayout>
  ) : (
    <DocsLayout
      title={doc.data.title}
      description={doc.data.description}
      slug={doc.id}
      resources={resources}
    >
      <Content />
    </DocsLayout>
  )
}
