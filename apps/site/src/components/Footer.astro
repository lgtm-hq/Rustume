---
import { cloudAppUrl } from '../lib/cloud-app-url';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const hostedAppUrl = cloudAppUrl();
---

<footer class="site-footer" data-pagefind-ignore>
  <div class="footer-inner">
    <div class="footer-grid">
      <div>
        <strong class="footer-brand">Rustume</strong>
        <p class="footer-tagline">Privacy-first resume builder, powered by Rust.</p>
      </div>
      <div class="footer-col">
        <h4>Docs</h4>
        <a href={`${base}docs/getting-started/quickstart/`}>Quick Start</a>
        <a href={`${base}docs/deployment/docker/`}>Deployment</a>
        <a href={`${base}cloud/`}>Rustume Cloud</a>
        <a href={hostedAppUrl} target="_blank" rel="noopener noreferrer">Open Rustume Cloud</a>
        <a href={`${base}docs/pricing/plans/`}>Pricing</a>
        <a href={`${base}faq/`}>FAQ</a>
        <a href={`${base}docs/api/overview/`}>API</a>
      </div>
      <div class="footer-col">
        <h4>Community</h4>
        <a href="https://github.com/lgtm-hq/Rustume" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://github.com/lgtm-hq/Rustume/issues" target="_blank" rel="noopener noreferrer">Issues</a>
        <a href="https://github.com/lgtm-hq/Rustume/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer">Contributing</a>
      </div>
    </div>
    <p class="footer-bottom">
      <a href={`${hostedAppUrl}/terms`}>Terms of Service</a>
      <span aria-hidden="true"> · </span>
      <a href={`${hostedAppUrl}/privacy`}>Privacy Policy</a>
      <span aria-hidden="true"> · </span>
      <a href={`${base}license/`}>AGPL-3.0</a> &copy; {year} Rustume
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid color-mix(in srgb, var(--site-accent, var(--rust-forge)) 15%, var(--turbo-border-default));
    background: color-mix(in srgb, var(--turbo-bg-surface) 90%, var(--site-accent, var(--rust-forge)) 10%);
    padding: 3rem 0 1.5rem;
    margin-top: 4rem;
  }
  .footer-inner { max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2rem; }
  .footer-brand {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
  }
  .footer-tagline { color: var(--turbo-text-muted); margin-top: 0.5rem; font-size: 0.9rem; }
  .footer-col { display: flex; flex-direction: column; gap: 0.4rem; }
  .footer-col h4 {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--site-accent-light, var(--rust-brass));
    margin-bottom: 0.25rem;
  }
  .footer-col a { color: var(--turbo-text-muted); font-size: 0.9rem; text-decoration: none; }
  .footer-col a:hover { color: var(--site-accent, var(--rust-forge)); }
  .footer-bottom { margin-top: 2rem; padding-top: 1rem; border-top: 1px solid var(--turbo-border-default); font-size: 0.8rem; color: var(--turbo-text-muted); }
  @media (max-width: 768px) { .footer-grid { grid-template-columns: 1fr; } }
</style>
