---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ExternalLinks from '../components/ExternalLinks.astro';
import {
  DEFAULT_THEME,
  NATIVE_THEME,
  themeAppearances,
  turboThemeIds,
  validThemeIds,
} from '../data/themes';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Rustume',
  description = 'Privacy-first, offline-first resume builder powered by Rust.',
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en" data-theme={DEFAULT_THEME} data-baseurl={baseUrl}>
  <head>
    <SEOHead title={title} description={description} />
    <link rel="stylesheet" href={`${baseUrl}/assets/css/turbo-core.css`} />
    <link rel="stylesheet" href={`${baseUrl}/assets/css/turbo-base.css`} />
    <link rel="stylesheet" href={`${baseUrl}/assets/css/turbo-syntax.css`} />
    <link rel="stylesheet" href={`${baseUrl}/assets/css/turbo-components.css`} />
    <link
      id="turbo-theme-css"
      rel="stylesheet"
      href={`${baseUrl}/assets/css/themes/${DEFAULT_THEME}.css`}
      disabled
    />
    <script
      is:inline
      define:vars={{ validThemeIds, turboThemeIds, NATIVE_THEME, DEFAULT_THEME, themeAppearances, baseUrl }}
    >
      (function () {
        var STORAGE_KEY = 'turbo-theme';

        function applyTheme(id) {
          var themeId = validThemeIds.indexOf(id) !== -1 ? id : DEFAULT_THEME;
          var isNative = themeId === NATIVE_THEME;
          var root = document.documentElement;
          var appearance = themeAppearances[themeId] || 'dark';

          root.setAttribute('data-theme', themeId);
          root.setAttribute('data-appearance', appearance);

          var link = document.getElementById('turbo-theme-css');
          if (link) {
            if (isNative) {
              link.setAttribute('disabled', 'true');
            } else {
              link.removeAttribute('disabled');
              link.href = baseUrl + '/assets/css/themes/' + themeId + '.css';
            }
          }

          try {
            localStorage.setItem(STORAGE_KEY, themeId);
          } catch (_) {}

          document.dispatchEvent(
            new CustomEvent('turbo-theme-applied', { detail: { themeId: themeId } })
          );
        }

        window.__applyTheme = applyTheme;

        try {
          var saved = localStorage.getItem(STORAGE_KEY) || DEFAULT_THEME;
          applyTheme(saved);
        } catch (e) {
          applyTheme(DEFAULT_THEME);
        }

        document.addEventListener('astro:page-load', function () {
          try {
            var saved = localStorage.getItem(STORAGE_KEY) || DEFAULT_THEME;
            applyTheme(saved);
          } catch (_) {
            applyTheme(DEFAULT_THEME);
          }
        });
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main class="main" id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <ExternalLinks />
  </body>
</html>
