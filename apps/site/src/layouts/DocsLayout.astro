---
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import DocsResources from '../components/docs/DocsResources.astro';
import { stripHtml, formatDocDescription, sanitizeDocDescription } from '../data/landing';
import type { DocResource } from '../lib/doc-resources';

interface Props {
  title: string;
  description: string;
  slug: string;
  resources?: DocResource[];
}

const { title, description, slug, resources } = Astro.props;
const base = import.meta.env.BASE_URL;
const metaDescription = stripHtml(description);
const formattedDescription = sanitizeDocDescription(formatDocDescription(description, base));
---

<BaseLayout title={title} description={metaDescription}>
  <div class="docs-layout">
    <DocsSidebar currentSlug={slug} />
    <main class="docs-main">
      <article class="docs-content" data-pagefind-body>
        <header class="docs-header">
          <h1 class="docs-title">{title}</h1>
          {description && <p class="docs-description" set:html={formattedDescription} />}
        </header>
        <div class="prose">
          <slot />
        </div>
        <DocsResources resources={resources ?? []} />
      </article>
    </main>
  </div>
</BaseLayout>
