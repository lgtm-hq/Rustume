---
import BaseLayout from "./BaseLayout.astro";
import DocsSectionNav from "../components/docs/DocsSectionNav.astro";
import DocsOnThisPage from "../components/docs/DocsOnThisPage.astro";
import DocsResources from "../components/docs/DocsResources.astro";
import { stripHtml, formatDocDescription, sanitizeDocDescription } from "../data/landing";
import type { DocCategory } from "../data/docs-nav";
import type { DocResource } from "../lib/doc-resources";

interface Props {
  title: string;
  description: string;
  slug: string;
  category?: DocCategory;
  resources?: DocResource[];
  toc?: boolean;
  showSectionNav?: boolean;
}

const {
  title,
  description,
  slug,
  category,
  resources,
  toc = true,
  showSectionNav = Boolean(category),
} = Astro.props;
const base = import.meta.env.BASE_URL;
const metaDescription = stripHtml(description);
const formattedDescription = sanitizeDocDescription(formatDocDescription(description, base));
---

<BaseLayout title={title} description={metaDescription}>
  <div class="docs-standalone">
    {showSectionNav && category && <DocsSectionNav category={category} currentSlug={slug} />}
    <div class="docs-standalone-body">
      <main class="docs-standalone-main">
        <article class="docs-content" data-pagefind-body>
          <header class="docs-header">
            <h1 class="docs-title">{title}</h1>
            {description && <p class="docs-description" set:html={formattedDescription} />}
          </header>
          <div class="prose">
            <slot />
          </div>
          <DocsResources resources={resources ?? []} />
        </article>
      </main>
      <DocsOnThisPage enabled={toc} />
    </div>
  </div>
</BaseLayout>
