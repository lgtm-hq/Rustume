# Docker Compose — cloud development profile
# Use with: docker compose --profile cloud up

POSTGRES_DB=rustume
POSTGRES_PASSWORD=rustume
POSTGRES_USER=rustume

CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://rustume:rustume@postgres:5432/rustume
RUSTUME_CLOUD=true

WORKOS_API_KEY=
# WorkOS AuthKit (from WorkOS dashboard)
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Session signing (generate: openssl rand -base64 32)
SESSION_SECRET=

# Transactional email (Resend) — set both to enable account lifecycle mail
EMAIL_FROM=
# RESEND_API_KEY=re_...
RESEND_API_KEY=

# Optional observability
SENTRY_DSN=

# Phase 1.5+ encryption
# ENCRYPTION_SECRET=

# Phase 2+ billing (Paddle sandbox)
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_CLIENT_TOKEN=

# Phase 2+ object storage (Cloudflare R2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
