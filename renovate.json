{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>lgtm-hq/.github:renovate-config"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^docker/Dockerfile$/"],
      "matchStrings": [
        "ARG BUN_VERSION=(?<currentValue>\\S+)",
        "BUN_VERSION=\"\\$\\{BUN_VERSION:-(?<currentValue>\\S+)\\}\""
      ],
      "depNameTemplate": "oven-sh/bun",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^bun-v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^docker/Dockerfile$/"],
      "matchStrings": [
        "cargo install cargo-chef@(?<currentValue>\\S+) --locked"
      ],
      "depNameTemplate": "cargo-chef",
      "datasourceTemplate": "crate"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^scripts/ci/site/preview-pages-local\\.sh$/"],
      "matchStrings": [
        "CARGO_LLVM_COV_VERSION=\"\\$\\{CARGO_LLVM_COV_VERSION:-(?<currentValue>\\S+)\\}\""
      ],
      "depNameTemplate": "cargo-llvm-cov",
      "datasourceTemplate": "crate"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["docker-compose", "dockerfile"],
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "groupName": "axum ecosystem",
      "groupSlug": "axum-ecosystem",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "axum",
        "axum-core",
        "axum-extra",
        "axum-macros",
        "tower",
        "tower-http",
        "utoipa",
        "utoipa-swagger-ui",
        "utoipa-axum"
      ]
    },
    {
      "groupName": "typst",
      "groupSlug": "typst",
      "matchManagers": ["cargo"],
      "matchPackageNames": [
        "typst",
        "typst-assets",
        "typst-pdf",
        "typst-render",
        "/^typst-/"
      ]
    },
    {
      "description": "apps/site must stay on TypeScript 6 until @astrojs/check supports the TypeScript 7 native API (astro#17268)",
      "matchFileNames": ["apps/site/package.json"],
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
